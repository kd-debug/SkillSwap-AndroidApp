rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile images are private and only readable/writable by the owner.
    match /profile_images/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Other storage objects require authentication by default.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
